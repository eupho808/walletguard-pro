{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "WalletGuard Pro",
  "version": "3.7.0",
  "description": "Independent security layer for Web3 wallets. Intercepts transactions, decodes calldata, analyzes Permit signatures, scans active ERC-20 + NFT approvals across 9 chains via public RPCs (no API key required), detects typosquatted domains, and blocks phishing sites before they reach MetaMask.",
  "browser_specific_settings": {
    "gecko": {
      "id": "walletguard-pro@walletguard.pro",
      "strict_min_version": "109.0"
    }
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://openrouter.ai/*",
    "https://eth.llamarpc.com/*",
    "https://optimism.llamarpc.com/*",
    "https://bsc-dataseed.bnbchain.org/*",
    "https://polygon-rpc.com/*",
    "https://fantom.publicnode.com/*",
    "https://mainnet.base.org/*",
    "https://arb1.arbitrum.io/*",
    "https://api.avax.network/*",
    "https://ethereum-sepolia-rpc.publicnode.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WalletGuard Pro"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "injector.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
